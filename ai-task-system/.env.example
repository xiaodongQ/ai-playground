# AI Task Pickup System - Environment Variables

# Database
TASK_DB_PATH=tasks.db

# Workspace for task execution
TASK_WORKSPACE_DIR=./workspace

# Scheduler settings
SCHEDULER_INTERVAL=60  # seconds between pickup checks
NUM_AGENTS=2  # number of concurrent AI agents

# API Keys (for evaluation)
ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_BASE_URL=  # leave empty for default, e.g., https://api.minimaxi.com

# Server
PORT=8000
