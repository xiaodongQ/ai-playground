# AI Task System V3 - Environment Variables

# 数据库
TASK_DB_PATH=./data/tasks.db

# 工作空间
WORKSPACE_ROOT=./workspace

# 服务配置
HOST=127.0.0.1
PORT=8000

# 调度器配置
SCHEDULER_INTERVAL=30
MAX_CONCURRENT_TASKS=2

# 超时配置
DEFAULT_ABSOLUTE_TIMEOUT=3600
DEFAULT_NO_OUTPUT_TIMEOUT=600

# CodeBuddy CLI
CODEBUDDY_CLI_PATH=codebuddy
